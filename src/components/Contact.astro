---
---

<section id="contact" class="relative py-28 px-6 section-animate" style="animation-delay: 0.5s">
  <!-- Big glow behind section -->
  <div class="absolute inset-0 pointer-events-none overflow-hidden">
    <div class="absolute bottom-0 left-1/2 -translate-x-1/2 w-[600px] h-[400px]"
      style="background: radial-gradient(ellipse, rgba(0,229,200,0.05) 0%, transparent 70%);">
    </div>
  </div>

  <div class="max-w-7xl mx-auto relative">
    <!-- Section label -->
    <div class="flex items-center gap-3 mb-4">
      <span class="font-mono text-[#00e5c8]/60 text-xs tracking-widest">06.</span>
      <span class="w-8 h-px bg-[#00e5c8]/40"></span>
    </div>

    <!-- Big CTA layout -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
      <div>
        <h2 class="text-5xl lg:text-6xl text-white mb-6 leading-tight">
          Let's build<br/>
          <span style="
            background: linear-gradient(135deg, #00e5c8 0%, #0077ff 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
          ">something great</span>
        </h2>
        <p class="text-lg text-white/50 leading-relaxed max-w-md">
          I'm always interested in discussing DevOps challenges, infrastructure automation,
          and how we can build more reliable systems together.
        </p>
      </div>

      <div class="space-y-4">
        <!-- Email -->
        <a
          href="mailto:contact@emadalhani.com"
          class="group flex items-center justify-between p-6 rounded-xl border border-white/10 bg-[#0d1117] hover:border-[#00e5c8]/50 hover:bg-[#0f1419] transition-all duration-300"
        >
          <div class="flex items-center gap-4">
            <div class="w-10 h-10 rounded-full border border-white/10 flex items-center justify-center text-white/40 group-hover:border-[#00e5c8]/50 group-hover:text-[#00e5c8] transition-all">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
              </svg>
            </div>
            <div>
              <div class="font-mono text-xs text-white/40 mb-0.5">Email</div>
              <div class="text-white font-medium text-sm">contact@emadalhani.com</div>
            </div>
          </div>
          <svg class="w-4 h-4 text-white/20 group-hover:text-[#00e5c8] group-hover:translate-x-1 transition-all" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        </a>

        <!-- GitHub -->
        <a
          href="https://github.com"
          target="_blank"
          rel="noopener noreferrer"
          class="group flex items-center justify-between p-6 rounded-xl border border-white/10 bg-[#0d1117] hover:border-[#00e5c8]/50 hover:bg-[#0f1419] transition-all duration-300"
        >
          <div class="flex items-center gap-4">
            <div class="w-10 h-10 rounded-full border border-white/10 flex items-center justify-center text-white/40 group-hover:border-[#00e5c8]/50 group-hover:text-[#00e5c8] transition-all">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
              </svg>
            </div>
            <div>
              <div class="font-mono text-xs text-white/40 mb-0.5">GitHub</div>
              <div class="text-white font-medium text-sm">github.com/emadalhani</div>
            </div>
          </div>
          <svg class="w-4 h-4 text-white/20 group-hover:text-[#00e5c8] group-hover:translate-x-1 transition-all" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        </a>

        <!-- LinkedIn -->
        <a
          href="https://linkedin.com"
          target="_blank"
          rel="noopener noreferrer"
          class="group flex items-center justify-between p-6 rounded-xl border border-white/10 bg-[#0d1117] hover:border-[#00e5c8]/50 hover:bg-[#0f1419] transition-all duration-300"
        >
          <div class="flex items-center gap-4">
            <div class="w-10 h-10 rounded-full border border-white/10 flex items-center justify-center text-white/40 group-hover:border-[#00e5c8]/50 group-hover:text-[#00e5c8] transition-all">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
              </svg>
            </div>
            <div>
              <div class="font-mono text-xs text-white/40 mb-0.5">LinkedIn</div>
              <div class="text-white font-medium text-sm">linkedin.com/in/emadalhani</div>
            </div>
          </div>
          <svg class="w-4 h-4 text-white/20 group-hover:text-[#00e5c8] group-hover:translate-x-1 transition-all" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>
