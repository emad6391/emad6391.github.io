---
const focusAreas = [
  {
    number: '01',
    icon: '⚡',
    title: 'CI/CD Automation',
    description: 'Designing and implementing robust pipelines with GitHub Actions and Jenkins — enabling teams to ship reliably and fast with automated testing, builds, and deployments.',
    tags: ['GitHub Actions', 'Jenkins'],
  },
  {
    number: '02',
    icon: '🏗️',
    title: 'Infrastructure as Code',
    description: 'Provisioning and managing cloud infrastructure using Terraform across AWS, Hetzner, and DigitalOcean. Reproducible, version-controlled, and modular at scale.',
    tags: ['Terraform', 'Ansible'],
  },
  {
    number: '03',
    icon: '☸️',
    title: 'Kubernetes & Containers',
    description: 'Running production-grade Kubernetes clusters (EKS, DOKS, Hetzner K3s) with ArgoCD for GitOps, Helm for packaging, and Docker for containerisation.',
    tags: ['Kubernetes', 'Docker', 'ArgoCD', 'Helm'],
  },
  {
    number: '04',
    icon: '☁️',
    title: 'Cloud Platforms',
    description: 'Multi-cloud expertise across AWS (EC2, S3, VPC, IAM, CloudWatch), DigitalOcean, and Hetzner — with Cloudflare for DNS, security, and performance at the edge.',
    tags: ['AWS', 'Hetzner', 'DigitalOcean', 'Cloudflare'],
  },
  {
    number: '05',
    icon: '📊',
    title: 'Monitoring & Observability',
    description: 'Full-stack observability with Prometheus for metrics and alerting, Elasticsearch for log management, and AWS CloudWatch — keeping systems transparent and healthy.',
    tags: ['Prometheus', 'Elasticsearch', 'CloudWatch'],
  },
  {
    number: '06',
    icon: '🔒',
    title: 'Security & Reliability',
    description: 'Embedding security and reliability throughout the stack — IAM policies, network segmentation, Cloudflare security rules, and automated backups for peace of mind.',
    tags: ['IAM', 'VPC', 'Cloudflare', 'Automation'],
  },
];
---

<section id="focus-areas" class="relative py-28 px-6 section-animate" style="animation-delay: 0.2s">
  <div class="max-w-7xl mx-auto">
    <div class="mb-16">
      <div class="flex items-center gap-3 mb-5">
        <span class="font-mono text-[#22d3ee]/60 text-xs tracking-widest">03.</span>
        <span class="w-8 h-px bg-[#22d3ee]/35"></span>
      </div>
      <h2 class="text-4xl lg:text-5xl text-white font-black leading-tight">Key Focus<br/>Areas</h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-px bg-white/6 rounded-2xl overflow-hidden border border-white/6">
      {focusAreas.map((area) => (
        <div class="group relative p-8 bg-[#0a0c14] hover:bg-[#0d1018] transition-colors duration-300 cursor-default overflow-hidden">

          <!-- Hover top bar -->
          <div class="absolute top-0 left-0 right-0 h-0.5 scale-x-0 group-hover:scale-x-100 transition-transform duration-400 origin-left"
            style="background: linear-gradient(90deg, #22d3ee, #818cf8)"></div>

          <!-- Watermark number -->
          <span class="absolute bottom-4 right-6 text-7xl font-black text-white/[0.025] group-hover:text-[#22d3ee]/[0.06] transition-colors select-none leading-none">
            {area.number}
          </span>

          <div class="relative space-y-4">
            <div class="w-11 h-11 rounded-lg border border-white/10 bg-white/4 flex items-center justify-center text-xl group-hover:border-[#22d3ee]/30 group-hover:bg-[#22d3ee]/8 transition-all">
              {area.icon}
            </div>

            <h3 class="text-lg font-bold text-white group-hover:text-[#22d3ee] transition-colors duration-300 leading-snug">
              {area.title}
            </h3>

            <p class="text-white/45 leading-relaxed text-sm">
              {area.description}
            </p>

            <div class="flex flex-wrap gap-1.5 pt-1">
              {area.tags.map(tag => (
                <span class="px-2.5 py-1 text-xs rounded-md border border-white/8 text-white/35 bg-white/3 group-hover:border-[#22d3ee]/20 group-hover:text-[#22d3ee]/60 transition-all">
                  {tag}
                </span>
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
