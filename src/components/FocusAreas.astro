---
interface FocusArea {
  number: string;
  title: string;
  description: string;
  icon: string;
}

const focusAreas: FocusArea[] = [
  {
    number: '01',
    title: 'Automation',
    description: 'Building automated workflows and scripts to reduce manual processes, improve consistency, and accelerate deployment cycles.',
    icon: '⚡'
  },
  {
    number: '02',
    title: 'CI/CD Pipelines',
    description: 'Designing and implementing robust continuous integration and deployment pipelines that enable teams to ship code reliably and quickly.',
    icon: '🔄'
  },
  {
    number: '03',
    title: 'Containerization',
    description: 'Leveraging Docker and container technologies to ensure applications are portable, scalable, and efficient across different environments.',
    icon: '📦'
  },
  {
    number: '04',
    title: 'Infrastructure as Code',
    description: 'Provisioning and managing cloud infrastructure using Terraform—reproducible, version-controlled, and maintainable at scale.',
    icon: '🏗️'
  }
];
---

<section id="focus-areas" class="relative py-28 px-6 section-animate" style="animation-delay: 0.2s">
  <!-- Subtle glow -->
  <div class="absolute left-0 right-0 top-1/2 -translate-y-1/2 h-px bg-gradient-to-r from-transparent via-[#00e5c8]/10 to-transparent pointer-events-none"></div>

  <div class="max-w-7xl mx-auto">
    <!-- Header -->
    <div class="flex items-end justify-between mb-16">
      <div>
        <div class="flex items-center gap-3 mb-4">
          <span class="font-mono text-[#00e5c8]/60 text-xs tracking-widest">03.</span>
          <span class="w-8 h-px bg-[#00e5c8]/40"></span>
        </div>
        <h2 class="text-4xl lg:text-5xl text-white">Key Focus<br/>Areas</h2>
      </div>
    </div>

    <!-- Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-px bg-white/5 rounded-xl overflow-hidden border border-white/5">
      {focusAreas.map((area, i) => (
        <div class="group relative p-8 lg:p-10 bg-[#0b0d14] hover:bg-[#0d1117] transition-colors duration-300 cursor-default">
          <!-- Number watermark -->
          <span class="absolute top-6 right-8 font-mono text-6xl font-black text-white/[0.03] group-hover:text-[#00e5c8]/[0.06] transition-colors select-none">
            {area.number}
          </span>

          <!-- Top bar on hover -->
          <div class="absolute top-0 left-0 right-0 h-0.5 bg-[#00e5c8] scale-x-0 group-hover:scale-x-100 transition-transform duration-400 origin-left"></div>

          <div class="relative space-y-4">
            <span class="text-2xl">{area.icon}</span>
            <h3 class="text-xl font-bold text-white group-hover:text-[#00e5c8] transition-colors duration-300">
              {area.title}
            </h3>
            <p class="text-white/50 leading-relaxed text-sm">
              {area.description}
            </p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
