---
import B12Link from './B12Link.astro';

interface Props {
  sectionLinks?: Array<{ label: string; href: string }>;
}

const { sectionLinks = [
  { label: 'About', href: '/index#about' },
  { label: 'Focus Areas', href: '/index#focus-areas' },
  { label: 'Certifications', href: '/index#certifications' },
  { label: 'Projects', href: '/index#projects' },
  { label: 'Contact', href: '/index#contact' }
] } = Astro.props;
---

<footer class="relative border-t border-white/5 mt-12">
  <div class="max-w-7xl mx-auto px-6 py-10">
    <div class="flex flex-col md:flex-row items-center justify-between gap-6">
      <div class="flex items-center gap-2">
        <span class="w-1.5 h-1.5 rounded-full bg-[#22d3ee]"></span>
        <span class="text-xs font-semibold tracking-[0.18em] text-white/40 uppercase">Emad Alhani</span>
      </div>
      <div class="flex flex-wrap justify-center items-center gap-5">
        {sectionLinks.map(link => (
          <a href={link.href} class="text-xs text-white/25 hover:text-white/70 transition-colors tracking-wide uppercase font-medium">
            {link.label}
          </a>
        ))}
      </div>
      <p class="text-xs text-white/20">© 2026</p>
    </div>
  </div>
  <!-- B12 attribution - kept but minimized -->
  <div class="b12-wrap">
    <B12Link />
  </div>
</footer>

<style>
  .b12-wrap {
    opacity: 0.18;
    filter: grayscale(1);
    transition: opacity 0.3s;
  }
  .b12-wrap:hover {
    opacity: 0.45;
  }
</style>
