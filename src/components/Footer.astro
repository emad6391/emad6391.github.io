---
const sectionLinks = [
  { label: 'About', href: '/index#about' },
  { label: 'Focus Areas', href: '/index#focus-areas' },
  { label: 'Certifications', href: '/index#certifications' },
  { label: 'Projects', href: '/index#projects' },
  { label: 'Contact', href: '/index#contact' },
];
---

<footer class="relative border-t border-white/6 mt-4">
  <div class="max-w-7xl mx-auto px-6 py-10">
    <div class="flex flex-col md:flex-row items-center justify-between gap-6">

      <div class="flex items-center gap-2.5">
        <div class="w-7 h-7 rounded-lg flex items-center justify-center text-xs font-black text-[#060810]"
          style="background: linear-gradient(135deg, #22d3ee, #818cf8)">EA</div>
        <span class="text-sm font-semibold text-white/40 tracking-wide">Emad Alhani</span>
      </div>

      <div class="flex flex-wrap justify-center items-center gap-5">
        {sectionLinks.map(link => (
          <a href={link.href} class="text-xs text-white/25 hover:text-white/65 transition-colors font-medium tracking-wide uppercase">
            {link.label}
          </a>
        ))}
      </div>

      <p class="text-xs text-white/18 font-mono">© 2026 Emad Alhani</p>
    </div>
  </div>
</footer>
