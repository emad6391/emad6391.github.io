---
---

<section id="hero" class="relative min-h-screen flex items-center px-6 pt-24 pb-16 section-animate overflow-hidden">

  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute top-1/4 left-1/2 -translate-x-1/2 w-[900px] h-[600px] rounded-full"
      style="background: radial-gradient(ellipse, rgba(34,211,238,0.07) 0%, rgba(129,140,248,0.03) 40%, transparent 70%);">
    </div>
  </div>

  <div class="max-w-7xl mx-auto w-full relative z-10">

    <div class="inline-flex items-center gap-3 mb-10 px-4 py-2 rounded-full border border-[#22d3ee]/20 bg-[#22d3ee]/5">
      <span class="w-2 h-2 rounded-full bg-[#22d3ee] animate-pulse"></span>
      <span class="font-mono text-[#22d3ee] text-xs tracking-[0.15em] uppercase">Available for new opportunities</span>
    </div>

    <h1 class="text-[clamp(3.8rem,9.5vw,8.5rem)] leading-[0.88] font-black text-white tracking-tight mb-10">
      Emad<br/>
      <span style="background: linear-gradient(100deg, #22d3ee 0%, #818cf8 55%, #c084fc 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">Alhani</span>
    </h1>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-end">

      <div class="space-y-8">
        <p class="text-lg text-white/50 leading-relaxed max-w-lg font-light">
          DevOps Engineer specialising in <span class="text-white font-medium">AWS</span>,
          <span class="text-white font-medium">Terraform</span>,
          <span class="text-white font-medium">Kubernetes</span> and
          <span class="text-white font-medium">CI/CD automation</span> across Hetzner and DigitalOcean.
          Focused on automation, reliability, and production-ready systems.
        </p>

        <!-- Stat row -->
        <div class="flex flex-wrap gap-6 py-2">
          <div>
            <div class="text-2xl font-black text-white">3+</div>
            <div class="text-xs text-white/35 font-medium tracking-wide mt-0.5">Certifications</div>
          </div>
          <div class="w-px h-10 bg-white/10"></div>
          <div>
            <div class="text-2xl font-black text-white">5</div>
            <div class="text-xs text-white/35 font-medium tracking-wide mt-0.5">Live Projects</div>
          </div>
          <div class="w-px h-10 bg-white/10"></div>
          <div>
            <div class="text-2xl font-black text-white">AWS</div>
            <div class="text-xs text-white/35 font-medium tracking-wide mt-0.5">+ Hetzner + DO</div>
          </div>
        </div>

        <div class="flex flex-wrap gap-3">
          <a href="/index#projects"
            class="group inline-flex items-center gap-2 px-7 py-3.5 rounded-lg font-bold text-sm text-[#060810] transition-all duration-300 hover:shadow-[0_12px_30px_rgba(34,211,238,0.3)] hover:-translate-y-0.5"
            style="background: linear-gradient(135deg, #22d3ee, #818cf8)">
            View Projects
            <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
            </svg>
          </a>
          <a href="/index#contact"
            class="inline-flex items-center gap-2 px-7 py-3.5 rounded-lg border border-white/15 bg-white/3 text-white/75 font-medium text-sm hover:border-[#22d3ee]/50 hover:text-[#22d3ee] hover:bg-[#22d3ee]/5 transition-all duration-300">
            Get in Touch
          </a>
        </div>
      </div>

      <!-- Terminal card -->
      <div class="relative">
        <div class="rounded-2xl border border-white/10 overflow-hidden bg-[#0d1117] hover:border-[#22d3ee]/25 transition-colors duration-500 shadow-[0_24px_60px_rgba(0,0,0,0.6)]">
          <div class="flex items-center gap-2 px-4 py-3 border-b border-white/8 bg-white/3">
            <span class="w-3 h-3 rounded-full bg-red-500/70"></span>
            <span class="w-3 h-3 rounded-full bg-yellow-500/70"></span>
            <span class="w-3 h-3 rounded-full bg-green-500/70"></span>
            <span class="ml-3 font-mono text-xs text-white/25">~/infra/eks-cluster.tf</span>
          </div>
          <div class="p-6 font-mono text-sm space-y-1.5 leading-7">
            <div><span class="text-purple-400">module</span> <span class="text-[#22d3ee]">"eks"</span> <span class="text-white/25">{"{"}</span></div>
            <div class="pl-5"><span class="text-blue-400">source</span>  <span class="text-white/25">=</span> <span class="text-green-400">"terraform-aws-modules/eks"</span></div>
            <div class="pl-5"><span class="text-blue-400">version</span> <span class="text-white/25">=</span> <span class="text-green-400">"~> 20.0"</span></div>
            <div class="pl-5"><span class="text-blue-400">cluster_name</span>    <span class="text-white/25">=</span> <span class="text-orange-300">var.cluster_name</span></div>
            <div class="pl-5"><span class="text-blue-400">cluster_version</span> <span class="text-white/25">=</span> <span class="text-green-400">"1.29"</span></div>
            <div class="pl-5"><span class="text-purple-400">vpc_id</span>          <span class="text-white/25">=</span> <span class="text-orange-300">module.vpc.vpc_id</span></div>
            <div><span class="text-white/25">{"}"}</span></div>
            <div class="pt-2 flex items-center gap-2 text-white/30">
              <span class="text-[#22d3ee]">$</span>
              <span>terraform apply --auto-approve</span>
              <span class="text-[#22d3ee] animate-pulse">█</span>
            </div>
          </div>
        </div>
        <div class="absolute -top-3 -right-3 px-3 py-1.5 rounded-full border border-[#22d3ee]/35 bg-[#060810] text-[#22d3ee] font-mono text-xs shadow-[0_0_20px_rgba(34,211,238,0.15)]">
          ✓ CKA · AWS · Terraform
        </div>
      </div>
    </div>
  </div>

  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 text-white/20" style="animation: float 3s ease-in-out infinite">
    <span class="font-mono text-[10px] tracking-[0.25em]">SCROLL</span>
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
    </svg>
  </div>
</section>

<style>
  @keyframes float {
    0%, 100% { transform: translateX(-50%) translateY(0); }
    50% { transform: translateX(-50%) translateY(8px); }
  }
</style>
