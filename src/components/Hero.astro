---
---

<section id="hero" class="relative min-h-screen flex items-center px-6 pt-24 pb-16 section-animate overflow-hidden">

  <!-- Radial glow backdrop -->
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute top-1/4 left-1/2 -translate-x-1/2 w-[800px] h-[500px] rounded-full"
      style="background: radial-gradient(ellipse, rgba(0,229,200,0.06) 0%, transparent 70%);">
    </div>
  </div>

  <div class="max-w-7xl mx-auto w-full relative z-10">
    <!-- Small eyebrow -->
    <div class="flex items-center gap-3 mb-8">
      <span class="w-8 h-px bg-[#00e5c8]"></span>
      <span class="font-mono text-[#00e5c8] text-xs tracking-[0.2em] uppercase">DevOps Engineer</span>
    </div>

    <!-- Main heading -->
    <div class="mb-8">
      <h1 class="text-[clamp(3.5rem,9vw,8rem)] leading-[0.9] font-black text-white tracking-tight">
        Emad<br/>
        <span style="
          background: linear-gradient(135deg, #00e5c8 0%, #00b4d8 50%, #0077ff 100%);
          -webkit-background-clip: text;
          -webkit-text-fill-color: transparent;
          background-clip: text;
        ">Alhani</span>
      </h1>
    </div>

    <!-- Two-column lower section -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-24 items-end">
      <!-- Left: description + CTA -->
      <div class="space-y-8">
        <p class="text-lg text-white/50 leading-relaxed max-w-md font-light">
          Building resilient cloud infrastructure with
          <span class="text-white font-medium">Terraform</span>,
          <span class="text-white font-medium">Kubernetes</span>, and
          <span class="text-white font-medium">CI/CD pipelines</span>
          that help teams ship faster with confidence.
        </p>

        <div class="flex flex-wrap gap-4">
          <a
            href="/index#projects"
            class="group inline-flex items-center gap-2 px-7 py-3.5 bg-[#00e5c8] text-[#0b0d14] font-bold text-sm rounded hover:shadow-[0_0_30px_rgba(0,229,200,0.4)] transition-all duration-300 hover:scale-105"
          >
            View Projects
            <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
            </svg>
          </a>
          <a
            href="/index#certifications"
            class="inline-flex items-center gap-2 px-7 py-3.5 border border-white/20 text-white font-medium text-sm rounded hover:border-[#00e5c8]/60 hover:text-[#00e5c8] transition-all duration-300"
          >
            Certifications
          </a>
        </div>
      </div>

      <!-- Right: terminal-style tech card -->
      <div class="relative">
        <div class="rounded-xl border border-white/10 overflow-hidden bg-[#0d1117] hover:border-[#00e5c8]/30 transition-colors duration-500 group">
          <!-- Terminal bar -->
          <div class="flex items-center gap-2 px-4 py-3 border-b border-white/10 bg-white/5">
            <span class="w-3 h-3 rounded-full bg-red-500/70"></span>
            <span class="w-3 h-3 rounded-full bg-yellow-500/70"></span>
            <span class="w-3 h-3 rounded-full bg-green-500/70"></span>
            <span class="ml-3 font-mono text-xs text-white/30">~/infrastructure/stack.tf</span>
          </div>
          <!-- Code-style content -->
          <div class="p-6 font-mono text-sm space-y-2">
            <div><span class="text-purple-400">resource</span> <span class="text-[#00e5c8]">"aws_eks_cluster"</span> <span class="text-orange-300">"production"</span> <span class="text-white/60">{"{"}</span></div>
            <div class="pl-4"><span class="text-blue-400">name</span> <span class="text-white/60">=</span> <span class="text-green-400">"prod-k8s-cluster"</span></div>
            <div class="pl-4"><span class="text-blue-400">version</span> <span class="text-white/60">=</span> <span class="text-green-400">"1.29"</span></div>
            <div class="pl-4 space-y-1">
              <div><span class="text-blue-400">tags</span> <span class="text-white/60">= {"{"}</span></div>
              <div class="pl-4"><span class="text-blue-400">Environment</span> <span class="text-white/60">=</span> <span class="text-green-400">"production"</span></div>
              <div class="pl-4"><span class="text-blue-400">ManagedBy</span>  <span class="text-white/60">=</span> <span class="text-green-400">"terraform"</span></div>
              <div><span class="text-white/60">{"}"}</span></div>
            </div>
            <div><span class="text-white/60">{"}"}</span></div>
            <div class="pt-2 flex items-center gap-2">
              <span class="text-[#00e5c8]">▶</span>
              <span class="text-white/40">terraform apply</span>
              <span class="animate-pulse text-[#00e5c8]">█</span>
            </div>
          </div>
        </div>

        <!-- Floating badges -->
        <div class="absolute -top-4 -right-4 px-3 py-1.5 rounded-full border border-[#00e5c8]/40 bg-[#0b0d14] text-[#00e5c8] font-mono text-xs shadow-[0_0_20px_rgba(0,229,200,0.15)]">
          ✓ 4 Certifications
        </div>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-0 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 text-white/20 animate-bounce">
      <span class="font-mono text-xs tracking-widest">SCROLL</span>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
      </svg>
    </div>
  </div>
</section>
