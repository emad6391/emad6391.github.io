---
const projects = [
  {
    index: '01',
    title: 'terraform-aws-infrastructure',
    description: 'Production-grade AWS infrastructure built with Terraform — VPC, subnets, security groups, EC2, S3, IAM roles, and CloudWatch monitoring. Modular architecture with remote state in S3 and DynamoDB locking.',
    techStack: ['Terraform', 'AWS', 'VPC', 'EC2', 'S3', 'IAM'],
    href: 'https://github.com/emadalhani/terraform-aws-infrastructure',
    accent: '#f59e0b',
  },
  {
    index: '02',
    title: 'ecs-fargate-terraform',
    description: 'Fully serverless container platform on AWS ECS Fargate, provisioned with Terraform. Auto-scaling, ALB, ECR image registry, and IAM task roles — zero server management.',
    techStack: ['Terraform', 'AWS ECS', 'Fargate', 'ECR', 'ALB'],
    href: 'https://github.com/emadalhani/ecs-fargate-terraform',
    accent: '#22d3ee',
  },
  {
    index: '03',
    title: 'k8s-hetzner-argocd',
    description: 'Kubernetes cluster on Hetzner Cloud using K3s with ArgoCD for GitOps-driven deployments. Automated provisioning with Terraform, Helm chart management, and Prometheus monitoring stack.',
    techStack: ['Kubernetes', 'Hetzner', 'ArgoCD', 'K3s', 'Terraform', 'Helm'],
    href: 'https://github.com/emadalhani/k8s-hetzner-argocd',
    accent: '#818cf8',
  },
  {
    index: '04',
    title: 'k8s-doks',
    description: 'Managed Kubernetes on DigitalOcean (DOKS) — cluster setup, networking, persistent volumes, and GitOps workflows. Load balancer integration and automated DNS via Cloudflare.',
    techStack: ['Kubernetes', 'DigitalOcean', 'DOKS', 'Cloudflare', 'Helm'],
    href: 'https://github.com/emadalhani/k8s-doks',
    accent: '#4ade80',
  },
  {
    index: '05',
    title: 'k8s-eks-argocd',
    description: 'Production EKS cluster on AWS with ArgoCD for continuous delivery. Terraform-provisioned, with IRSA, Cluster Autoscaler, AWS Load Balancer Controller, and full observability via Prometheus.',
    techStack: ['AWS EKS', 'ArgoCD', 'Terraform', 'Kubernetes', 'Prometheus', 'IRSA'],
    href: 'https://github.com/emadalhani/k8s-eks-argocd',
    accent: '#c084fc',
  },
];
---

<section id="projects" class="relative py-28 px-6 section-animate" style="animation-delay: 0.4s">
  <div class="max-w-7xl mx-auto">
    <div class="mb-16">
      <div class="flex items-center gap-3 mb-5">
        <span class="font-mono text-[#22d3ee]/60 text-xs tracking-widest">05.</span>
        <span class="w-8 h-px bg-[#22d3ee]/35"></span>
      </div>
      <h2 class="text-4xl lg:text-5xl text-white font-black leading-tight">Featured<br/>Projects</h2>
    </div>

    <div class="space-y-4">
      {projects.map((project) => (
        <a
          href={project.href}
          target="_blank"
          rel="noopener noreferrer"
          class="group relative flex flex-col sm:flex-row sm:items-center gap-5 sm:gap-7 p-7 rounded-xl border border-white/8 bg-[#0d1117] hover:border-white/16 hover:bg-[#0f1420] transition-all duration-300 overflow-hidden no-underline"
        >
          <!-- Left accent bar -->
          <div class="absolute left-0 top-0 bottom-0 w-0.5 scale-y-0 group-hover:scale-y-100 transition-transform duration-400 origin-top rounded-r"
            style={`background: ${project.accent}`}></div>

          <!-- Index -->
          <div class="flex-shrink-0 sm:w-14">
            <span class="font-mono text-3xl font-black text-white/[0.05] group-hover:text-white/[0.12] transition-colors">
              {project.index}
            </span>
          </div>

          <!-- Divider -->
          <div class="hidden sm:block w-px h-14 bg-white/8 group-hover:bg-white/15 transition-colors flex-shrink-0"></div>

          <!-- Content -->
          <div class="flex-grow min-w-0">
            <div class="flex items-start gap-3 mb-2.5">
              <h3 class="font-mono text-base font-semibold text-white group-hover:text-white transition-colors leading-snug">
                {project.title}
              </h3>
              <span class="flex-shrink-0 w-4 h-4 mt-0.5 text-white/20 group-hover:text-white/60 transition-colors">
                <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
                </svg>
              </span>
            </div>
            <p class="text-white/40 text-sm leading-relaxed mb-4 max-w-2xl">
              {project.description}
            </p>
            <div class="flex flex-wrap gap-1.5">
              {project.techStack.map(tech => (
                <span class="px-2.5 py-1 font-mono text-xs rounded-md border border-white/8 text-white/35 bg-white/3 group-hover:border-white/15 group-hover:text-white/55 transition-all">
                  {tech}
                </span>
              ))}
            </div>
          </div>

          <!-- Arrow -->
          <div class="hidden sm:flex flex-shrink-0 w-9 h-9 rounded-lg border border-white/8 items-center justify-center text-white/20 group-hover:border-white/25 group-hover:text-white/60 group-hover:bg-white/5 transition-all">
            <svg class="w-4 h-4 group-hover:translate-x-0.5 group-hover:-translate-y-0.5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 17L17 7M17 7H7M17 7v10"/>
            </svg>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
